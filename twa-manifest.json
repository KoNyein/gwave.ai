{
  "$comment": "Bubblewrap manifest for the gwave.ai Play Store (TWA) build. Built automatically by .github/workflows/build-apk.yml (Actions -> Build Android APK). See docs/PLAY_STORE.md.",
  "packageId": "ai.gwave.app",
  "host": "gwave-ai.vercel.app",
  "name": "gwave.ai",
  "launcherName": "gwave",
  "display": "standalone",
  "orientation": "portrait",
  "themeColor": "#3B6D11",
  "backgroundColor": "#EAF3DE",
  "navigationColor": "#3B6D11",
  "startUrl": "/feed",
  "iconUrl": "https://gwave-ai.vercel.app/icon-512.png",
  "maskableIconUrl": "https://gwave-ai.vercel.app/icon-512.png",
  "splashScreenFadeOutDuration": 300,
  "enableNotifications": true,
  "isChromeOSOnly": false,
  "shortcuts": [
    {
      "name": "Feed",
      "short_name": "Feed",
      "url": "/feed",
      "chosenIconUrl": "https://gwave-ai.vercel.app/icon-512.png"
    },
    {
      "name": "Messenger",
      "short_name": "Chat",
      "url": "/messages",
      "chosenIconUrl": "https://gwave-ai.vercel.app/icon-512.png"
    },
    {
      "name": "Learn",
      "short_name": "Learn",
      "url": "/learn",
      "chosenIconUrl": "https://gwave-ai.vercel.app/icon-512.png"
    },
    {
      "name": "Shop",
      "short_name": "Shop",
      "url": "/shop",
      "chosenIconUrl": "https://gwave-ai.vercel.app/icon-512.png"
    }
  ],
  "fallbackType": "customtabs",
  "enableSiteSettingsShortcut": true,
  "minSdkVersion": 21,
  "appVersionName": "1.0.0",
  "appVersionCode": 1,
  "webManifestUrl": "https://gwave-ai.vercel.app/manifest.webmanifest",
  "fullScopeUrl": "https://gwave-ai.vercel.app/",
  "signingKey": {
    "path": "./android.keystore",
    "alias": "gwave"
  }
}