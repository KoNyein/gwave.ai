# gwave.ai — server environment for deploy/docker-compose.prod.yml
# Copy to the repo root as `.env` on the AWS box and fill in. Never commit .env.
#
#   cp deploy/.env.server.example .env
#
# NEXT_PUBLIC_* are baked into the browser bundle at build time; everything else
# is read at runtime by the server. Rebuild (docker compose ... up --build) after
# changing any NEXT_PUBLIC_* value.

# --- Core (Supabase — database/auth/storage) --------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key         # server only — keep secret
# Self-hosted Supabase + Cognito only: the project's JWT secret (the same value
# used to generate the anon/service keys; PostgREST's PGRST_JWT_SECRET). When
# Cognito auth is on, the app signs a short-lived {role:authenticated, sub}
# token with this so a self-hosted PostgREST authorises writes. Leave blank on
# Supabase Cloud (its third-party auth handles this) — server only, keep secret.
SUPABASE_JWT_SECRET=

# Canonical public URL of the site (used for auth redirects, share links).
NEXT_PUBLIC_SITE_URL=https://gwave.cc

# --- Live (LiveKit SFU) — browser broadcast + co-host ----------------------
# Set all three to route Live through LiveKit (no Mux needed). Self-host with
# deploy/livekit-setup.sh / livekit-cloudformation.yaml, or use LiveKit Cloud.
NEXT_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Payments (Stripe) — membership + G-Pay top-up -------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- G-Pay phone OTP (Twilio SMS) ------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Web push notifications (PWA) ------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Optional integrations --------------------------------------------------
# Messenger calls TURN relay
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
# CCTV (self-hosted media server)
NEXT_PUBLIC_CCTV_PLAYER_ORIGIN=
NEXT_PUBLIC_CCTV_HLS_ORIGINS=
NEXT_PUBLIC_CCTV_APP=LiveApp
CCTV_MEDIA_API_URL=
CCTV_MEDIA_API_TOKEN=
# CCTV via Amazon KVS WebRTC (sub-second). Server mints short-lived viewer
# creds; the long-lived key never reaches the browser. See deploy/kvs-master.
KVS_AWS_REGION=
KVS_AWS_ACCESS_KEY_ID=
KVS_AWS_SECRET_ACCESS_KEY=
# Maps, games, misc
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GAME_FRAME_ORIGINS=
NEXT_PUBLIC_GPAY_KPAY_NUMBER=
NEXT_PUBLIC_SENTRY_DSN=
# Amazon Cognito (auth migration — see docs/COGNITO_SETUP.md). Leave every value
# blank to stay on Supabase Auth; the app switches to Cognito only when ALL five
# are set. Server-only — the client secret must never reach the browser.
COGNITO_REGION=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=
# Set to 1 (together with the five COGNITO_* above) to switch login to Cognito.
# Baked into the browser bundle at build time; leave blank to stay on Supabase.
NEXT_PUBLIC_COGNITO_ENABLED=
