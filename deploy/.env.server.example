# gwave.ai — server environment for deploy/docker-compose.prod.yml
# Copy to the repo root as `.env` on the AWS box and fill in. Never commit .env.
#
#   cp deploy/.env.server.example .env
#
# NEXT_PUBLIC_* are baked into the browser bundle at build time; everything else
# is read at runtime by the server. Rebuild (docker compose ... up --build) after
# changing any NEXT_PUBLIC_* value.

# --- Core (Supabase — database/auth/storage live at supabase.com) -----------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key         # server only — keep secret

# Canonical public URL of the site (used for auth redirects, share links).
NEXT_PUBLIC_SITE_URL=https://gwave.cc

# --- Live (LiveKit SFU) — browser broadcast + co-host ----------------------
# Set all three to route Live through LiveKit (no Mux needed). Self-host with
# deploy/livekit-setup.sh / livekit-cloudformation.yaml, or use LiveKit Cloud.
NEXT_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Payments (Stripe) — membership + G-Pay top-up -------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Health / wearable sync — optional; each provider dormant until its keys set
# Fitbit (free) — https://dev.fitbit.com — OAuth app, redirect:
#   https://gwave.cc/api/health/fitbit/callback
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
# Google Fit (free, but the REST API is DEPRECATED by Google) — Cloud OAuth
# client with fitness scopes, redirect: https://gwave.cc/api/health/google/callback
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=
# NOTE: the manual log + phone step-counter need no keys — they always work.

# --- G-Pay phone OTP (Twilio SMS) ------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Web push notifications (PWA) ------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Optional integrations --------------------------------------------------
# Messenger calls TURN relay
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
# CCTV (self-hosted media server)
NEXT_PUBLIC_CCTV_PLAYER_ORIGIN=
NEXT_PUBLIC_CCTV_HLS_ORIGINS=
NEXT_PUBLIC_CCTV_APP=LiveApp
CCTV_MEDIA_API_URL=
CCTV_MEDIA_API_TOKEN=
# Maps, games, misc
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GAME_FRAME_ORIGINS=
NEXT_PUBLIC_GPAY_KPAY_NUMBER=
NEXT_PUBLIC_SENTRY_DSN=
