# KVS WebRTC master config. Copy to `.env` and fill in. Never commit `.env`.

# The signaling channel name you created in the AWS console (Step 1).
KVS_CHANNEL=Hydroponics-Cam

# AWS region of that channel.
KVS_REGION=ap-southeast-1
AWS_DEFAULT_REGION=ap-southeast-1

# IAM user access keys with KVS permission (Step 2). Keep secret.
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Your camera's RTSP source (same URL you'd use for an RTSP camera in the app).
# Tapo: rtsp://USER:PASS@192.168.1.100:554/stream1
RTSP_URL=rtsp://USER:PASS@192.168.1.100:554/stream1

# 1=error 2=warn 3=info 4=debug
AWS_KVS_LOG_LEVEL=2
