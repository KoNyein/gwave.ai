# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only. NEVER expose to the client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (membership billing) — server only
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PromptPay (Thai QR payments) — phone number, national ID or e-wallet ID
PROMPTPAY_ID=0800000000

# Developer dashboard deploy panel (Coolify API) — server only
COOLIFY_API_URL=https://coolify.example.com
COOLIFY_API_TOKEN=your-coolify-token
COOLIFY_APP_UUID=your-app-uuid
# Shown on /dev/deploy (set from CI: GIT_COMMIT_SHA=$GITHUB_SHA)
GIT_COMMIT_SHA=
