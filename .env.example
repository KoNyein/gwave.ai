# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only. NEVER expose to the client or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL (used for OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (membership billing) — server only
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PromptPay (Thai QR payments) — phone number, national ID or e-wallet ID
PROMPTPAY_ID=0800000000

# Mux (live streaming) — server only. Create an access token at
# https://dashboard.mux.com/settings/access-tokens (Mux Video permission),
# and a webhook signing secret when adding the webhook endpoint (see README).
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SECRET=your-mux-webhook-signing-secret

# GreenWave CCTV — an external media server (Ant Media Server or LiveKit on
# your own infra, e.g. an AWS EC2 instance) carries the actual camera video.
# All optional: cameras and share links work without these, but won't stream
# live video until they are set.
#   CCTV_MEDIA_API_URL       Server-side REST base incl. the app path, used to
#                            register/tear down streams. Never exposed publicly.
#   CCTV_MEDIA_API_TOKEN     Optional bearer token / JWT for that REST API.
#   NEXT_PUBLIC_CCTV_PLAYER_ORIGIN  Public origin of the media server that the
#                            browser player iframe loads (also allow-listed in
#                            the CSP frame-src). Origin only, no trailing slash.
#   NEXT_PUBLIC_CCTV_APP     Media-server application name (Ant Media: LiveApp).
CCTV_MEDIA_API_URL=
CCTV_MEDIA_API_TOKEN=
NEXT_PUBLIC_CCTV_PLAYER_ORIGIN=
NEXT_PUBLIC_CCTV_APP=LiveApp

# Optional TURN relay for messenger audio/video calls. Without it, calls use
# Google's public STUN server, which works on most networks; strict/symmetric
# NATs need a TURN service (e.g. Twilio, metered.ca, coturn).
NEXT_PUBLIC_TURN_URL=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=

# LiveKit (SFU / media server) for co-host Live. When set, co-host Live routes
# media through the LiveKit server so a few publishers can broadcast to
# thousands of viewers. When unset, co-host Live falls back to the peer-to-peer
# WebRTC mesh (good for ~6 co-hosts, no server). Self-host with
# deploy/livekit-setup.sh, or use LiveKit Cloud.
#   LIVEKIT_API_KEY / LIVEKIT_API_SECRET  server-only, mint access tokens
#   NEXT_PUBLIC_LIVEKIT_URL               wss:// URL the browser connects to
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# Developer dashboard deploy panel (Coolify API) — server only
COOLIFY_API_URL=https://coolify.example.com
COOLIFY_API_TOKEN=your-coolify-token
COOLIFY_APP_UUID=your-app-uuid
# Shown on /dev/deploy (set from CI: GIT_COMMIT_SHA=$GITHUB_SHA)
GIT_COMMIT_SHA=

# Game portal: trusted origins (space-separated) whose games may be embedded in
# an iframe — e.g. your AWS S3/CloudFront host. phet.colorado.edu is built in.
NEXT_PUBLIC_GAME_FRAME_ORIGINS=

# Play Store (TWA) — Digital Asset Links served at /.well-known/assetlinks.json
# Set after `bubblewrap build`; see docs/PLAY_STORE.md.
TWA_PACKAGE_NAME=
TWA_SHA256_FINGERPRINT=

# Web Push (PWA/TWA notifications). Generate with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@gwave.ai

# Chat attachments live in a private "chat-media" bucket, read back through
# /api/media/chat. During the one-time backfill (scripts/migrate-chat-media.mjs),
# set this to 1 so attachments not yet copied still load from the old public
# bucket. Set back to 0 (or unset) once `--mode=verify` passes — leaving it on
# would silently serve a public URL whenever signing fails.
CHAT_MEDIA_FALLBACK_PUBLIC=0

# Only when NEXT_PUBLIC_S3_CDN is set (the dormant S3 storage backend): the S3
# bucket name for private chat attachments, alongside AWS_S3_MEDIA_BUCKET /
# AWS_S3_SLIPS_BUCKET. Unset while storage is on Supabase.
AWS_S3_CHAT_BUCKET=
