# Generated platform folders — regenerated by `flutter create .` in CI.
# Keep lib/, pubspec.yaml, assets/ and the workflow under version control;
# android/ and ios/ are scaffolded fresh at build time so we don't commit
# machine-specific signing/config.
/android/
/ios/
/linux/
/macos/
/windows/
/web/

